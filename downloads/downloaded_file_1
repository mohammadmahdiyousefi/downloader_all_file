// Download button countdown
var activeTimer = null;

document.querySelectorAll('.btn-simple-download').forEach(function(btn) {
    btn.dataset.ready = "0"; // initial state

    btn.addEventListener('click', function(e) {

        // ✅ If ready, allow normal download
        if (btn.dataset.ready === "1") {
            return;
        }

        // ❌ First click: block download
        e.preventDefault();

        var total = 10; // seconds (keep 3–5)
        var left  = total;

        var box   = document.getElementById('dl-countdown-box');
        var count = document.getElementById('dl-count');
        var bar   = document.getElementById('dl-bar');

        if (activeTimer) clearInterval(activeTimer);

        // Hide all download buttons
        document.querySelectorAll('.btn-simple-download').forEach(function(b) {
            b.style.display = 'none';
        });

        // Show countdown box
        box.style.display = 'block';
        count.textContent = left;
        bar.style.transition = 'none';
        bar.style.width = '0%';

        // Animate progress bar
        requestAnimationFrame(function() {
            requestAnimationFrame(function() {
                bar.style.transition = 'width ' + total + 's linear';
                bar.style.width = '100%';
            });
        });

        activeTimer = setInterval(function() {
            left--;
            count.textContent = left > 0 ? left : 0;

            if (left <= 0) {
                clearInterval(activeTimer);

                // Hide countdown + progress bar
                box.style.display = 'none';

                // Show buttons again and mark ready
                document.querySelectorAll('.btn-simple-download').forEach(function(b) {
                    b.dataset.ready = "1";
                    b.style.display = 'inline-block';
                    b.innerText = "Download Now";
                });
            }
        }, 1000);
    });
});

// Load More Comments Functionality
const loadMoreBtn = document.getElementById('load-more-comments');
if (loadMoreBtn) {
loadMoreBtn.addEventListener('click', async function() {
const songId = this.dataset.songId;
const offset = parseInt(this.dataset.offset);
const loadingText = document.getElementById('loading-text');
const commentsList = document.getElementById('comments-list');
// Show loading
this.disabled = true;
this.style.opacity = '0.6';
loadingText.style.display = 'block';
try {
const response = await fetch(`/load-comments.php?song_id=${songId}&offset=${offset}`);
const data = await response.json();
if (data.success) {
// Append new comments
commentsList.insertAdjacentHTML('beforeend', data.html);
// Update offset
this.dataset.offset = data.newOffset;
// Hide button if no more comments
if (!data.hasMore) {
this.parentElement.style.display = 'none';
}
} else {
alert('Failed to load comments. Please try again.');
}
} catch (error) {
console.error('Error loading comments:', error);
alert('Error loading comments. Please check your connection.');
} finally {
// Hide loading
this.disabled = false;
this.style.opacity = '1';
loadingText.style.display = 'none';
}
});
}
</script>
